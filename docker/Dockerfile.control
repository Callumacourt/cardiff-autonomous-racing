# Control module Dockerfile
FROM cardiff-autonomous-racing_base

# Install additional dependencies for EUFS
RUN apt-get update && apt-get install -y \
    iproute2 \
    can-utils \
    kmod \
    python3-numpy \
    python3-scipy \
    python3-matplotlib \
    build-essential \
    cmake \
    ros-humble-ackermann-msgs \
    ros-humble-geometry-msgs \
    ros-humble-std-msgs \
    ros-humble-sensor-msgs \
    ros-humble-std-srvs \
    ros-humble-tf2 \
    ros-humble-tf2-ros \
    ros-humble-nav-msgs \
    ros-humble-visualization-msgs \
    && rm -rf /var/lib/apt/lists/*

# Install Python packages for control algorithms
RUN pip3 install \
    numpy \
    scipy \
    matplotlib \
    control

# Set up workspace
WORKDIR /workspace
RUN mkdir -p /workspace/control_ws/src

# Copy Control modules and REAL eufs_msgs
COPY Control/ros_control/ /workspace/control_ws/src/ros_control/
COPY Control/ros_can/ /workspace/control_ws/src/ros_can/
COPY Control/eufs_msgs/ /workspace/control_ws/src/eufs_msgs/

# Build control workspace with real EUFS messages
WORKDIR /workspace/control_ws
RUN /bin/bash -c '. /opt/ros/humble/setup.bash && \
echo "🔧 Building EUFS messages..." && \
colcon build --symlink-install --packages-select eufs_msgs --cmake-args -DCMAKE_BUILD_TYPE=Release && \
echo "✅ EUFS messages built successfully" && \
. install/setup.bash && \
echo "🔧 Building ros_control package..." && \
colcon build --symlink-install --packages-select ros_control --cmake-args -DCMAKE_BUILD_TYPE=Release && \
echo "🔧 Building ros_can package..." && \
colcon build --symlink-install --packages-select ros_can --cmake-args -DCMAKE_BUILD_TYPE=Release'

# Copy entrypoint
COPY docker/entrypoint_control.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

COPY Control/logs/ /workspace/control_ws/logs/
RUN ln -sf /dev/stdout /workspace/control_ws/logs/control_output.log
RUN ls -sf /dev/stdout /workspace/control_ws/logs/ros_can_output.log

WORKDIR /workspace

ENTRYPOINT ["/entrypoint.sh"]