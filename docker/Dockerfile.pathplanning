
FROM cardiff-racing:base


RUN mkdir -p /workspace/planning_ws/src/path_planning


COPY "Path Planning/" /workspace/planning_ws/src/path_planning/

RUN echo '<?xml version="1.0"?>' > /workspace/planning_ws/src/path_planning/package.xml && \
    echo '<?xml-model href="http://download.ros.org/schema/package_format3.xsd" schematypens="http://www.w3.org/2001/XMLSchema"?>' >> /workspace/planning_ws/src/path_planning/package.xml && \
    echo '<package format="3">' >> /workspace/planning_ws/src/path_planning/package.xml && \
    echo '  <name>path_planning</name>' >> /workspace/planning_ws/src/path_planning/package.xml && \
    echo '  <version>0.0.0</version>' >> /workspace/planning_ws/src/path_planning/package.xml && \
    echo '  <description>RRT* Path Planning for Autonomous Racing</description>' >> /workspace/planning_ws/src/path_planning/package.xml && \
    echo '  <maintainer email="callumacourtt@gmail.com">callumacourt</maintainer>' >> /workspace/planning_ws/src/path_planning/package.xml && \
    echo '  <license>MIT</license>' >> /workspace/planning_ws/src/path_planning/package.xml && \
    echo '  <depend>rclpy</depend>' >> /workspace/planning_ws/src/path_planning/package.xml && \
    echo '  <depend>std_msgs</depend>' >> /workspace/planning_ws/src/path_planning/package.xml && \
    echo '  <depend>nav_msgs</depend>' >> /workspace/planning_ws/src/path_planning/package.xml && \
    echo '  <depend>geometry_msgs</depend>' >> /workspace/planning_ws/src/path_planning/package.xml && \
    echo '  <export><build_type>ament_python</build_type></export>' >> /workspace/planning_ws/src/path_planning/package.xml && \
    echo '</package>' >> /workspace/planning_ws/src/path_planning/package.xml


RUN echo "from setuptools import setup" > /workspace/planning_ws/src/path_planning/setup.py && \
    echo "package_name = 'path_planning'" >> /workspace/planning_ws/src/path_planning/setup.py && \
    echo "setup(" >> /workspace/planning_ws/src/path_planning/setup.py && \
    echo "    name=package_name," >> /workspace/planning_ws/src/path_planning/setup.py && \
    echo "    version='0.0.0'," >> /workspace/planning_ws/src/path_planning/setup.py && \
    echo "    packages=[package_name]," >> /workspace/planning_ws/src/path_planning/setup.py && \
    echo "    py_modules=['integration', 'rrt_star']," >> /workspace/planning_ws/src/path_planning/setup.py && \
    echo "    install_requires=['setuptools']," >> /workspace/planning_ws/src/path_planning/setup.py && \
    echo "    zip_safe=True," >> /workspace/planning_ws/src/path_planning/setup.py && \
    echo "    maintainer='callumacourt'," >> /workspace/planning_ws/src/path_planning/setup.py && \
    echo "    maintainer_email='callumacourtt@gmail.com'," >> /workspace/planning_ws/src/path_planning/setup.py && \
    echo "    description='Path planning using RRT*'," >> /workspace/planning_ws/src/path_planning/setup.py && \
    echo "    license='MIT'," >> /workspace/planning_ws/src/path_planning/setup.py && \
    echo "    entry_points={" >> /workspace/planning_ws/src/path_planning/setup.py && \
    echo "        'console_scripts': [" >> /workspace/planning_ws/src/path_planning/setup.py && \
    echo "            'path_planner = integration:main'," >> /workspace/planning_ws/src/path_planning/setup.py && \
    echo "        ]," >> /workspace/planning_ws/src/path_planning/setup.py && \
    echo "    }," >> /workspace/planning_ws/src/path_planning/setup.py && \
    echo ")" >> /workspace/planning_ws/src/path_planning/setup.py

WORKDIR /workspace/planning_ws
RUN . /opt/ros/humble/setup.sh && \
    colcon build --symlink-install

# Copy entrypoint
COPY docker/entrypoint_planning.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

ENTRYPOINT ["/entrypoint.sh"]