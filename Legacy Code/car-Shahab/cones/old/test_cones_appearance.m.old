if 0
    fn = list_files('patches_blue/*.png');
    
    N = numel(fn);
    im = imread(fn{1});
    [h, w, d] = size(im);
    X = zeros(h * w * d, N);
    Xf = zeros(h * w * d, N);
    
    for i = 1:N
        im = im2double(imread(fn{i}));
        X(:, i) = im(:);
        imf = fliplr(im);
        Xf(:, i) = imf(:);
    end
    
    X = [X Xf];
    [B, eval, avg] = kspca(X);
end

keep = 10;
proj = B(:, 1:keep)' * subcol(X, avg);

figure(1); clf;

% K = 4;
% [idx, C] = kmeans(proj', K, 'MaxIter', 10000, ...
%     'Display', 'final', 'Replicates', 10);
% hold on
% for i = 1:K
plot(proj(3, :), proj(4, :), '.');
% end

figure(2); clf;
sc(reshape(B, 32, 24, 3, []))

% hold off
V = [];
for evec = 1:7
    sigma = std(proj(evec, :));
    std(proj(evec, :))
    n = 9;
    param = linspace(-3, 3, n) * sigma;
    c = zeros(size(proj, 1), n);
    c(evec, :) = param;
    
    unproj = addcol(B(:, 1:keep) * c, avg);
    V = [V; (reshape(permute(reshape(unproj, 32, 24, 3, n), [1 2 4 3]), 32, 24 * n, 3))];
end
    figure(3); clf;
    sc(V);
