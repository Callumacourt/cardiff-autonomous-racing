%%% \mysection - replacement for \section
% with colored section-title and automatic numbering
%\newcounter{section}
\setcounter{section}{1}
\newcommand{\mysection}[1]{
  \vspace{1cm}
  \begin{center}
 %   \shabox{
  \colorbox{mainCol}{
      \begin{minipage}[c][50pt][c]{0.9\columnwidth}
        \vspace{2.5mm}
        \begin{center}
      \Large{
          {\sffamily\bfseries\textcolor{TextCol}{{\fontspec{TruenoUltLt}\uppercase{#1}}}}
      }
        \end{center}
        \vfill
      \end{minipage}
    }
%}
  \end{center}
  \par\vspace{0.75cm}
  \stepcounter{section}
}

%%% \myplainsection - replacement for \section
\newcommand{\myplainsection}[1]{
  \vspace{2cm}
  {\bf\textcolor{TextCol}{\arabic{section}.~#1}}
  \par\vspace{0.75cm}
  \stepcounter{section}
}

%%% \mysubsection - replacement for \subsection
\newcommand{\mysubsection}[1]{
  \vspace{1cm}
  {\bf\textcolor{TextCol}{#1}}
  \par\vspace{0.75cm}
}

%%% \myfig - replacement for \figure
% necessary, since in multicol-environment \figure won't work
\newcommand{\myfig}[3][0]{
\begin{center}
  \vspace{1cm}
  \includegraphics[width=#3\hsize,angle=#1]{#2}
  \nobreak\medskip
\end{center}}

%%% \mycaption - replacement for \caption
% necessary, since in multicol-environment \figure and
% therefore \caption won't work
%\newcounter{figure}
\setcounter{figure}{1}
\newcommand{\mycaption}[1]{
  \vspace{0.5cm}\par
  {\renewcommand{\baselinestretch}{1}\small
   \setbox0=\hbox{\sc Figure \arabic{figure}: \sl #1}
   \ifdim\wd0>\hsize
     {\sc Figure \arabic{figure}: \sl #1}
   \else
     \centerline{\box0}
   \fi
   \par
   \stepcounter{figure}
  }
}

\newcounter{alg}
\setcounter{alg}{1}
\newcommand{\myalgcaption}[1]{
  \vspace{0.5cm}\par
  {\renewcommand{\baselinestretch}{1}\small
   \setbox0=\hbox{\sc Algorithm \arabic{alg}: \sl #1}
   \ifdim\wd0>\hsize
     {\sc Algorithm \arabic{alg}: \sl #1}
   \else
     \centerline{\box0}
   \fi
   \par
   \stepcounter{alg}
  }
}

